# =============================================================================
# .gitignore for the HRM mechanistic-interpretability fork
# =============================================================================

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Virtual envs
.venv/
venv/
.env

# IDE / editor
.vscode/
.idea/
*.swp

# Large model / numerical artefacts
*.pt
*.ckpt
*.pth
*.npy
*.npz
*.tar.gz
*.run

# Data / outputs / experiment artefacts (large)
data/
outputs/
wandb/
logs/
checkpoints/

# Per-puzzle logs that should not be committed
experiments/paper_replication/results/easy_hard_analysis/results.json

# Paper / submission artefacts (kept out of repo)
paper/*
!paper/figures/
!paper/figures/**
icml2026.zip

# PDFs (paper/figures excepted above)
docs/*.pdf
*.log
